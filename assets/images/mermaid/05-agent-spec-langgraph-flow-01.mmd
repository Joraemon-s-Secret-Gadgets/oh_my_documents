graph TD
    START(["User / UI Input"]) --> INTENT["Intent_Agent<br/>(entry node)"]
    INTENT --> NEED{"필수 조건 충족?"}
    NEED -- "아니오" --> FOLLOWUP["추가 질문 생성"]
    FOLLOWUP --> END_WAIT(["END<br/>사용자 응답 대기"])

    NEED -- "예" --> SUP["Supervisor_Router"]

    subgraph MATRIX["fulfilled_matrix routing"]
        SUP --> E_CHECK{"evidence = X?"}
        E_CHECK -- "예" --> EVIDENCE["Candidate_Evidence_Agent"]
        EVIDENCE --> SUP
        E_CHECK -- "아니오" --> F_CHECK{"festival = X?"}
        F_CHECK -- "예" --> FESTIVAL["Festival_Verifier_Agent"]
        FESTIVAL --> SUP
        F_CHECK -- "아니오" --> P_CHECK{"planning = X?"}
    end

    P_CHECK -- "예" --> PLANNER["Planner_Agent<br/>(일정 · 설명 · 검증)"]
    P_CHECK -- "아니오" --> PLANNER

    PLANNER --> VALID{"검증 통과?"}
    VALID -- "예" --> SERVE["Backend_Serving / SAM"]
    VALID -- "아니오<br/>retry < 2" --> SUP
    VALID -- "아니오<br/>retry >= 2" --> FALLBACK["안전 폴백 응답"]
    FALLBACK --> SERVE
    SERVE --> END(["Final Response"])
