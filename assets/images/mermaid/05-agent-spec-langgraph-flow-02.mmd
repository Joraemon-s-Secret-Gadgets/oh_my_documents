graph TD
    USER["User / UI"] --> INTENT["Intent_Agent"]
    INTENT --> NEED{"Need more info?"}
    NEED -- "Yes" --> ASK["Follow-up Question"]
    ASK --> USER
    NEED -- "No" --> SUP["Supervisor_Router"]

    SUP -->|"evidence"| EVIDENCE["Candidate_Evidence_Agent"]
    EVIDENCE --> SUP

    SUP -->|"festival"| FESTIVAL["Festival_Verifier_Agent"]
    FESTIVAL --> SUP

    SUP -->|"planning"| PLANNER["Planner_Agent"]
    PLANNER --> VALID{"Pass?"}
    VALID -- "Retry" --> SUP
    VALID -- "Fallback" --> FALLBACK["Safe Fallback"]
    VALID -- "Pass" --> SERVE["Backend_Serving / SAM"]
    FALLBACK --> SERVE
    SERVE --> USER
