  classDef pipelineNode fill:#fff2cc,stroke:#d6b656,color:#1f2937;
  classDef externalNode fill:#f5f5f5,stroke:#666666,color:#1f2937;

  class user externalNode;
  class edge,imagecdn edgeNode;
